<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Catálogo LayerUp - Impresión 3D</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Space -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400;1,700&display=swap"
        rel="stylesheet">
    <!-- Noto Sans -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:ital,wght@0,100..900;1,100..900&display=swap"
        rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            blue: '#3693CE',
                            dark: '#153A52',
                            light: '#44B6DF',
                        }
                    },
                    fontFamily: {
                        space: ['Space Mono', 'sans-serif'],
                        sans: ['Noto Sans', 'sans-serif']
                    }
                }
            }
        }
    </script>
    <style>
        /* Estilos base y de impresión */
        body {
            background-color: #f3f4f6;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }

        /* Patrón de cuadrícula */
        .bg-pattern {
            background-color: #ffffff;
            background-image:
                linear-gradient(#e0f2fe 1px, transparent 1px),
                linear-gradient(90deg, #e0f2fe 1px, transparent 1px);
            background-size: 40px 40px;
            position: relative;
        }

        /* Olas decorativas de fondo */
        .bg-pattern::before {
            content: "";
            position: absolute;
            top: -10%;
            left: -10%;
            width: 120%;
            height: 120%;
            background:
                radial-gradient(circle at 30% 20%,
                    rgba(54, 133, 181, 0.05) 0%,
                    transparent 40%),
                radial-gradient(circle at 80% 60%,
                    rgba(54, 133, 181, 0.05) 0%,
                    transparent 50%);
            z-index: 0;
            pointer-events: none;
        }

        /* Estilo Polaroid para los productos */
        .polaroid {
            background: white;
            padding: 12px 12px 20px 12px;
            box-shadow:
                0 10px 25px -5px rgba(0, 0, 0, 0.1),
                0 8px 10px -6px rgba(0, 0, 0, 0.1);
            border: 1px solid #f1f5f9;
            transition: transform 0.3s ease;
            break-inside: avoid;
            /* Evita que el producto se corte a la mitad en el PDF */
        }

        /* Rotaciones sutiles alternadas para dar efecto de fotos apiladas */
        @media screen {
            .polaroid-tilt-1 {
                transform: rotate(-2deg);
            }

            .polaroid-tilt-2 {
                transform: rotate(1.5deg);
            }

            .polaroid-tilt-3 {
                transform: rotate(-1deg);
            }

            .polaroid-tilt-4 {
                transform: rotate(2deg);
            }

            .polaroid:hover {
                transform: rotate(0deg) scale(1.02);
                z-index: 10;
            }
        }

        /* Banda azul lateral */
        .catalog-container {
            border-right: 32px solid #3693CE;
        }

        /* Quita los encabezados y pies de página por defecto */
        @page {
            size: auto;
            margin: 0mm;
        }

        @media print {
            body {
                background-color: white;
                padding: 10mm 15mm !important;
            }

            /* 1. DESTRUIR FLEXBOX Y GRID EN TODO EL ÁRBOL */
            /* Si un contenedor padre es flex, el salto de página falla */
            main.catalog-container,
            section,
            .grid {
                display: block !important;
                min-height: auto !important;
                height: auto !important;
            }

            .catalog-container {
                box-shadow: none;
                margin: 0;
                max-width: 100%;
                border-right: 20px solid #3693CE;
            }

            header {
                break-after: avoid;
                page-break-after: avoid;
            }

            /* 2. DISEÑO A LA ANTIGUA (FLOAT) PARA GARANTIZAR QUE NO SE CORTE */
            .polaroid {
                display: block !important;
                float: left !important;
                /* Mantiene el diseño de 2 columnas */
                width: 44% !important;
                /* Casi la mitad */
                margin: 0 3% 20px 3% !important;
                /* Espaciado uniforme */

                /* Magia absoluta anti-cortes */
                page-break-inside: avoid !important;
                break-inside: avoid !important;
                -webkit-column-break-inside: avoid !important;

                /* Limpieza visual */
                transform: none !important;
                box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1) !important;
                border: 1px solid #e5e7eb !important;
            }

            /* 3. LIMPIAR LOS FLOATS PARA QUE EL CONTENEDOR NO COLAPSE */
            .grid::after {
                content: "";
                display: table;
                clear: both;
            }

            .print-hide {
                display: none !important;
            }
        }
    </style>
</head>

